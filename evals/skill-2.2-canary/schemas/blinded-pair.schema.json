{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "pair_id", "task_id", "profile", "deliverable", "request", "output_a", "output_b", "pair_sha256"],
  "properties": {
    "schema_version": {"const": "skill-2.2-pair-1.0"},
    "pair_id": {"type": "string", "pattern": "^PAIR-[0-9]{2}$"},
    "task_id": {"type": "string"},
    "profile": {"enum": ["compact", "standard", "full-audit"]},
    "deliverable": {"type": "string", "minLength": 1},
    "request": {"type": "string", "minLength": 1},
    "output_a": {"type": "string", "minLength": 1},
    "output_b": {"type": "string", "minLength": 1},
    "pair_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
