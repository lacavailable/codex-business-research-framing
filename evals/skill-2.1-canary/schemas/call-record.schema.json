{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "call_id", "task_id", "role", "condition", "model", "reasoning", "prompt_sha256", "status", "attempts"],
  "properties": {
    "schema_version": {"const": "skill-canary-call-1.0"},
    "call_id": {"type": "string", "pattern": "^(GEN|JUDGE)-[0-9]{2}$"},
    "task_id": {"type": "string"},
    "role": {"enum": ["generation", "blind_pairwise_judge"]},
    "condition": {"enum": ["v0.2", "skill-2.1", "blinded"]},
    "model": {"enum": ["gpt-5.6-terra", "gpt-5.6-sol"]},
    "reasoning": {"const": "high"},
    "prompt_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "status": {"enum": ["planned", "complete", "invalid", "paused_resource_limit"]},
    "attempts": {"type": "integer", "minimum": 0, "maximum": 1}
  }
}
