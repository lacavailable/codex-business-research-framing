{"$schema":"https://json-schema.org/draft/2020-12/schema","title":"Lean Role C adversarial verification record","type":"object","additionalProperties":false,"required":["schema_version","record_id","case_id","role","role_a_id","role_b_id","role_a_sealed_at","role_b_sealed_at","started_at","sealed_at","prompt_hash","model","fresh_context","confidence","verifications"],"properties":{"schema_version":{"const":"3.1.0-lean.1"},"record_id":{"type":"string","pattern":"^LRC-[0-9a-f]{16}$"},"case_id":{"type":"string","pattern":"^(OM|IS|OR|MGMT)-P[0-9]{2}$"},"role":{"const":"role_c"},"role_a_id":{"type":"string","pattern":"^LRA-[0-9a-f]{16}$"},"role_b_id":{"type":"string","pattern":"^LRB-[0-9a-f]{16}$"},"role_a_sealed_at":{"type":"string","format":"date-time"},"role_b_sealed_at":{"type":"string","format":"date-time"},"started_at":{"type":"string","format":"date-time"},"sealed_at":{"type":"string","format":"date-time"},"prompt_hash":{"type":"string","pattern":"^[0-9a-f]{64}$"},"model":{"type":"object"},"fresh_context":{"const":true},"confidence":{"type":"number","minimum":0,"maximum":1},"verifications":{"type":"array","items":{"type":"object","additionalProperties":false,"required":["topic","decision","material","reason","evidence_span_ids"],"properties":{"topic":{"type":"string","minLength":1},"decision":{"enum":["confirm","challenge_with_evidence","uncertain"]},"material":{"type":"boolean"},"reason":{"type":"string","minLength":1},"evidence_span_ids":{"type":"array","items":{"type":"string","pattern":"^ES-[0-9]{3}$"},"uniqueItems":true}}}}}}
