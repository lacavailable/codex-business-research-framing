{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Resumable lean run manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "stage", "split", "required_call_cap", "conditional_adjudication_cap", "maximum_calls", "calls_used", "status", "holdouts_opened", "created_at", "updated_at", "calls"],
  "properties": {
    "schema_version": {"const": "3.1.0-lean.1"},
    "run_id": {"type": "string", "pattern": "^LRUN-[0-9a-f]{16}$"},
    "stage": {"enum": ["D0", "D1", "D2", "validation"]},
    "split": {"enum": ["development", "validation"]},
    "required_call_cap": {"type": "integer", "minimum": 0},
    "conditional_adjudication_cap": {"type": "integer", "minimum": 0},
    "maximum_calls": {"type": "integer", "minimum": 0},
    "calls_used": {"type": "integer", "minimum": 0},
    "status": {"enum": ["planned", "running", "complete", "incomplete", "failed", "paused_resource_limit"]},
    "holdouts_opened": {"const": false},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "calls": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["call_id", "call_kind", "case_id", "role", "prompt_hash", "provider", "model_id", "family_claim", "settings", "status", "attempts", "output_path", "output_sha256", "schema_valid", "started_at", "completed_at"],
        "properties": {
          "call_id": {"type": "string", "pattern": "^LCALL-[0-9a-f]{16}$"},
          "call_kind": {"enum": ["required", "conditional"]},
          "case_id": {"type": "string", "pattern": "^(OM|IS|OR|MGMT)-P[0-9]{2}$"},
          "role": {"enum": ["role_a", "role_b", "role_c", "contrast_judge", "adjudicator"]},
          "prompt_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "provider": {"const": "OpenAI"},
          "model_id": {"enum": ["gpt-5.6-sol", "gpt-5.6-terra"]},
          "family_claim": {"const": "same_family"},
          "settings": {
            "type": "object",
            "additionalProperties": false,
            "required": ["reasoning_effort", "sampling_controls"],
            "properties": {
              "reasoning_effort": {"enum": ["high", "xhigh"]},
              "sampling_controls": {"const": "not_exposed"}
            }
          },
          "status": {"enum": ["planned", "running", "completed", "schema_invalid", "needs_adjudication", "paused_resource_limit", "not_required"]},
          "attempts": {"type": "integer", "minimum": 0},
          "output_path": {"type": ["string", "null"]},
          "output_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
          "schema_valid": {"type": ["boolean", "null"]},
          "started_at": {"type": ["string", "null"], "format": "date-time"},
          "completed_at": {"type": ["string", "null"], "format": "date-time"}
        }
      }
    }
  }
}
