{"$schema":"https://json-schema.org/draft/2020-12/schema","title":"Resumable lean run manifest","type":"object","additionalProperties":false,"required":["schema_version","run_id","stage","split","maximum_calls","calls_used","status","holdouts_opened","created_at","updated_at","calls"],"properties":{"schema_version":{"const":"3.1.0-lean.1"},"run_id":{"type":"string","pattern":"^LRUN-[0-9a-f]{16}$"},"stage":{"enum":["D0","D1","D2","validation"]},"split":{"enum":["development","validation"]},"maximum_calls":{"type":"integer","minimum":0},"calls_used":{"type":"integer","minimum":0},"status":{"enum":["planned","running","complete","incomplete","failed","paused_resource_limit"]},"holdouts_opened":{"const":false},"created_at":{"type":"string","format":"date-time"},"updated_at":{"type":"string","format":"date-time"},"calls":{"type":"array","items":{"type":"object","additionalProperties":false,"required":["call_id","case_id","role","prompt_hash","model_id","settings","status","attempts","output_path","output_sha256","schema_valid","started_at","completed_at"],"properties":{"call_id":{"type":"string","pattern":"^LCALL-[0-9a-f]{16}$"},"case_id":{"type":"string","pattern":"^(OM|IS|OR|MGMT)-P[0-9]{2}$"},"role":{"enum":["role_a","role_b","role_c","contrast_judge","adjudicator"]},"prompt_hash":{"type":"string","pattern":"^[0-9a-f]{64}$"},"model_id":{"type":"string","minLength":1},"settings":{"type":"object"},"status":{"enum":["planned","running","completed","schema_invalid","needs_adjudication","paused_resource_limit"]},"attempts":{"type":"integer","minimum":0},"output_path":{"type":["string","null"]},"output_sha256":{"type":["string","null"],"pattern":"^[0-9a-f]{64}$"},"schema_valid":{"type":["boolean","null"]},"started_at":{"type":["string","null"],"format":"date-time"},"completed_at":{"type":["string","null"],"format":"date-time"}}}}}}
