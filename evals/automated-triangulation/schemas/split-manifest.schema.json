{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/frame-business-research-problem/automated-triangulation/split-manifest.schema.json",
  "title": "Source-clustered automated calibration split manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "manifest_id", "created_from_commit", "expert_holdout_state", "automated_holdout_state", "source_cluster_policy", "cases", "manifest_sha256"],
  "properties": {
    "schema_version": {"const": "3.0.0-automated.1"},
    "manifest_id": {"type": "string", "pattern": "^ASM-[0-9a-f]{16}$"},
    "created_from_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "expert_holdout_state": {"const": "expert_holdout_unopened"},
    "automated_holdout_state": {"enum": ["automated_holdout_unopened", "automated_holdout_opened"]},
    "source_cluster_policy": {"const": "one_source_cluster_one_split"},
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["case_id", "source_cluster_id", "domain", "split", "silver_status", "case_sha256"],
        "properties": {
          "case_id": {"type": "string", "pattern": "^AC[0-9a-f]{16}$"},
          "source_cluster_id": {"type": "string", "pattern": "^SC-[0-9a-f]{12}$"},
          "domain": {"enum": ["OM", "IS", "OR", "MGMT"]},
          "split": {"enum": ["development", "validation", "holdout"]},
          "silver_status": {"enum": ["silver_high_confidence", "silver_provisional", "unresolved"]},
          "case_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      },
      "uniqueItems": true
    },
    "manifest_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
