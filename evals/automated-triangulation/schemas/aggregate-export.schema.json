{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/frame-business-research-problem/automated-triangulation/aggregate-export.schema.json",
  "title": "Public-safe aggregate automated calibration export",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "export_id", "claim_label", "split", "case_counts", "metrics", "private_content_excluded", "human_experts_participated", "expert_holdout_state", "source_manifest_sha256"],
  "properties": {
    "schema_version": {"const": "3.0.0-automated.1"},
    "export_id": {"type": "string", "pattern": "^AAE-[0-9a-f]{16}$"},
    "claim_label": {"const": "automated source-grounded triangulation"},
    "split": {"enum": ["development", "validation", "holdout", "combined"]},
    "case_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["OM", "IS", "OR", "MGMT", "total"],
      "properties": {
        "OM": {"type": "integer", "minimum": 0},
        "IS": {"type": "integer", "minimum": 0},
        "OR": {"type": "integer", "minimum": 0},
        "MGMT": {"type": "integer", "minimum": 0},
        "total": {"type": "integer", "minimum": 0}
      }
    },
    "metrics": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["metric_id", "value", "unit", "sample_size"],
        "properties": {
          "metric_id": {"type": "string", "minLength": 1},
          "value": {"type": ["number", "null"]},
          "unit": {"enum": ["proportion", "points", "count", "correlation", "rate"]},
          "sample_size": {"type": "integer", "minimum": 0},
          "confidence_interval_95": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "required": ["lower", "upper"],
            "properties": {"lower": {"type": "number"}, "upper": {"type": "number"}}
          }
        }
      }
    },
    "private_content_excluded": {
      "type": "object",
      "additionalProperties": false,
      "required": ["passage_text", "evidence_spans", "pdfs", "raw_annotations", "expert_identities"],
      "properties": {
        "passage_text": {"const": true},
        "evidence_spans": {"const": true},
        "pdfs": {"const": true},
        "raw_annotations": {"const": true},
        "expert_identities": {"const": true}
      }
    },
    "human_experts_participated": {"const": false},
    "expert_holdout_state": {"const": "expert_holdout_unopened"},
    "source_manifest_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
