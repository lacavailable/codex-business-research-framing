{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/frame-business-research-problem/automated-triangulation/contrast-metadata.schema.json",
  "title": "One-primary-construct contrast metadata",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "contrast_id", "original_case_id", "variant_case_id", "source_cluster_id", "split", "variant_type", "primary_construct", "expected_affected_category", "expected_unaffected_categories", "expected_atomic_failure", "minimum_directional_change", "unaffected_category_tolerance", "acceptable_ambiguity", "copyright_scope"],
  "properties": {
    "schema_version": {"const": "3.0.0-automated.1"},
    "contrast_id": {"type": "string", "pattern": "^ACT-[0-9a-f]{16}$"},
    "original_case_id": {"type": "string", "pattern": "^AC[0-9a-f]{16}$"},
    "variant_case_id": {"type": "string", "pattern": "^AC[0-9a-f]{16}$"},
    "source_cluster_id": {"type": "string", "pattern": "^SC-[0-9a-f]{12}$"},
    "split": {"enum": ["development", "validation", "holdout"]},
    "variant_type": {"enum": ["actor_perturbation", "timing_perturbation", "information_perturbation", "objective_perturbation", "mechanism_deletion", "trade_off_deletion", "unsupported_empirical_claim_insertion", "unsupported_causal_pathway_insertion", "generic_gap_replacement", "boundary_deletion", "verbosity_insertion", "prestige_label_manipulation", "faithful_paraphrase", "simplified_concise_rewrite"]},
    "primary_construct": {"enum": ["actor", "timing", "information", "objective", "mechanism", "trade_off", "empirical_support", "causal_support", "contribution", "boundaries", "verbosity", "prestige", "paraphrase", "conciseness"]},
    "expected_affected_category": {"enum": ["fidelity", "managerial_framing", "scholarly_positioning", "evidence_discipline", "prose_clarity", "none"]},
    "expected_unaffected_categories": {"type": "array", "items": {"enum": ["fidelity", "managerial_framing", "scholarly_positioning", "evidence_discipline", "prose_clarity"]}, "uniqueItems": true},
    "expected_atomic_failure": {"type": ["string", "null"], "enum": [null, "actor_wrong", "decision_timing_changed", "future_information_used", "hidden_information_assumed_observed", "state_treated_as_decision", "behavioral_mechanism_changed", "material_constraint_removed", "objective_substituted", "profit_or_revenue_called_welfare", "equivalent_formulation_claimed_to_change_true_optimum", "runtime_directly_converted_to_profit", "post_deadline_certificate_claimed_to_change_executed_decision", "invented_empirical_fact", "unsupported_causal_claim", "hidden_major_assumption"]},
    "minimum_directional_change": {"type": "number", "minimum": 0},
    "unaffected_category_tolerance": {"type": "number", "minimum": 0},
    "acceptable_ambiguity": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "copyright_scope": {"enum": ["private_source_derived", "public_original_synthetic"]}
  }
}
