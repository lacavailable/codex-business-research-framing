{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/frame-business-research-problem/automated-triangulation/atomic-fidelity-result.schema.json",
  "title": "Atomic fidelity audit",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "case_id", "applicability", "checks", "hard_failures", "uncertain_rate"],
  "properties": {
    "schema_version": {"const": "3.0.0-automated.1"},
    "case_id": {"type": "string", "pattern": "^AC[0-9a-f]{16}$"},
    "applicability": {"enum": ["required", "optional", "not_applicable"]},
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actor_wrong", "decision_timing_changed", "future_information_used", "hidden_information_assumed_observed", "state_treated_as_decision", "behavioral_mechanism_changed", "material_constraint_removed", "objective_substituted", "profit_or_revenue_called_welfare", "equivalent_formulation_claimed_to_change_true_optimum", "runtime_directly_converted_to_profit", "post_deadline_certificate_claimed_to_change_executed_decision", "invented_empirical_fact", "unsupported_causal_claim", "hidden_major_assumption"],
      "properties": {
        "actor_wrong": {"$ref": "#/$defs/check"},
        "decision_timing_changed": {"$ref": "#/$defs/check"},
        "future_information_used": {"$ref": "#/$defs/check"},
        "hidden_information_assumed_observed": {"$ref": "#/$defs/check"},
        "state_treated_as_decision": {"$ref": "#/$defs/check"},
        "behavioral_mechanism_changed": {"$ref": "#/$defs/check"},
        "material_constraint_removed": {"$ref": "#/$defs/check"},
        "objective_substituted": {"$ref": "#/$defs/check"},
        "profit_or_revenue_called_welfare": {"$ref": "#/$defs/check"},
        "equivalent_formulation_claimed_to_change_true_optimum": {"$ref": "#/$defs/check"},
        "runtime_directly_converted_to_profit": {"$ref": "#/$defs/check"},
        "post_deadline_certificate_claimed_to_change_executed_decision": {"$ref": "#/$defs/check"},
        "invented_empirical_fact": {"$ref": "#/$defs/check"},
        "unsupported_causal_claim": {"$ref": "#/$defs/check"},
        "hidden_major_assumption": {"$ref": "#/$defs/check"}
      }
    },
    "hard_failures": {
      "type": "array",
      "uniqueItems": true,
      "items": {"enum": ["actor_wrong", "decision_timing_changed", "future_information_used", "hidden_information_assumed_observed", "state_treated_as_decision", "behavioral_mechanism_changed", "material_constraint_removed", "objective_substituted", "profit_or_revenue_called_welfare", "equivalent_formulation_claimed_to_change_true_optimum", "runtime_directly_converted_to_profit", "post_deadline_certificate_claimed_to_change_executed_decision", "invented_empirical_fact", "unsupported_causal_claim", "hidden_major_assumption"]}
    },
    "uncertain_rate": {"type": "number", "minimum": 0, "maximum": 1}
  },
  "$defs": {
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["verdict", "material", "hard_failure", "evidence_span_ids", "rationale"],
      "properties": {
        "verdict": {"enum": ["yes", "no", "uncertain"]},
        "material": {"type": "boolean"},
        "hard_failure": {"type": "boolean"},
        "evidence_span_ids": {"type": "array", "items": {"type": "string", "pattern": "^ES-[0-9]{3}$"}, "uniqueItems": true},
        "rationale": {"type": "string", "minLength": 1}
      },
      "allOf": [
        {
          "if": {"properties": {"hard_failure": {"const": true}}, "required": ["hard_failure"]},
          "then": {
            "properties": {
              "verdict": {"const": "yes"},
              "material": {"const": true},
              "evidence_span_ids": {"minItems": 1}
            }
          }
        }
      ]
    }
  }
}
