{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/frame-business-research-problem/automated-triangulation/context-packet.schema.json",
  "title": "Private source-grounded context packet",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "packet_id", "case_id", "source_id", "source_cluster_id", "domain", "passage_function", "requested_task", "intended_audience", "source_sha256", "passage_sha256", "confidentiality", "context", "evidence_spans"],
  "properties": {
    "schema_version": {"const": "3.0.0-automated.1"},
    "packet_id": {"type": "string", "pattern": "^ACP-[0-9a-f]{16}$"},
    "case_id": {"type": "string", "pattern": "^AC[0-9a-f]{16}$"},
    "source_id": {"type": "string", "pattern": "^(OM|IS|OR|MGMT)-[0-9]{3}$"},
    "source_cluster_id": {"type": "string", "pattern": "^SC-[0-9a-f]{12}$"},
    "domain": {"enum": ["OM", "IS", "OR", "MGMT"]},
    "passage_function": {"enum": ["phenomenon_motivation", "business_problem", "model_setting", "research_opportunity", "contribution", "managerial_implications"]},
    "requested_task": {"type": "string", "minLength": 1},
    "intended_audience": {"type": "string", "minLength": 1},
    "source_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "passage_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "confidentiality": {"const": "private_local_only"},
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actor", "decisions", "timing", "decision_time_information", "objective", "constraints", "mechanism", "study_or_model_facts", "boundaries"],
      "properties": {
        "actor": {"type": ["string", "null"]},
        "decisions": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "timing": {"type": ["string", "null"]},
        "decision_time_information": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "objective": {"type": ["string", "null"]},
        "constraints": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "mechanism": {"type": ["string", "null"]},
        "study_or_model_facts": {"type": "array", "items": {"type": "string"}, "minItems": 1, "uniqueItems": true},
        "boundaries": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
      }
    },
    "evidence_spans": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/evidence_span"}
    }
  },
  "$defs": {
    "evidence_span": {
      "type": "object",
      "additionalProperties": false,
      "required": ["span_id", "location", "text", "supports"],
      "properties": {
        "span_id": {"type": "string", "pattern": "^ES-[0-9]{3}$"},
        "location": {"type": "string", "minLength": 1},
        "text": {"type": "string", "minLength": 1},
        "supports": {"type": "array", "items": {"type": "string"}, "minItems": 1, "uniqueItems": true}
      }
    }
  }
}
