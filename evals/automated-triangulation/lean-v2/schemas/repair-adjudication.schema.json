{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/frame-business-research-problem/automated-triangulation/lean-v2/repair-adjudication.schema.json",
  "title": "D2R dispute classification and authoritative semantic adjudication",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "dispute_id", "case_id", "primary_class", "material_semantic", "procedural_correction", "trigger", "competing_record_ids", "competing_conclusions", "evidence_span_ids", "resolution", "adjudicator_invoked", "authoritative"],
  "properties": {
    "schema_version": {"const": "3.1.0-lean.2"},
    "dispute_id": {"type": "string", "pattern": "^RAD-[0-9a-f]{16}$"},
    "case_id": {"type": "string", "pattern": "^(OM|IS|OR|MGMT)-P[0-9]{2}$"},
    "primary_class": {"enum": ["material_semantic_disagreement", "applicability_boundary_disagreement", "evidence_localization_mismatch", "schema_or_format_mismatch", "terminology_only_difference", "insufficient_context", "invalid_challenge"]},
    "material_semantic": {"type": "boolean"},
    "procedural_correction": {"type": "boolean"},
    "trigger": {"enum": ["applicability", "fidelity", "evidence_support_status", "category_localization", "hard_failure", "packet_or_schema"]},
    "competing_record_ids": {"type": "array", "minItems": 2, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "competing_conclusions": {"type": "array", "minItems": 2, "items": {"type": "object", "additionalProperties": false, "required": ["record_id", "conclusion"], "properties": {"record_id": {"type": "string", "minLength": 1}, "conclusion": {"type": "string", "minLength": 1}}}},
    "evidence_span_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^ES-[0-9]{3}$"}},
    "resolution": {"type": "string", "minLength": 1},
    "adjudicator_invoked": {"type": "boolean"},
    "authoritative": {"type": "boolean"}
  },
  "allOf": [
    {"if": {"properties": {"material_semantic": {"const": true}}}, "then": {"properties": {"adjudicator_invoked": {"const": true}, "authoritative": {"const": true}, "evidence_span_ids": {"minItems": 1}}}},
    {"if": {"properties": {"procedural_correction": {"const": true}}}, "then": {"properties": {"adjudicator_invoked": {"const": false}, "authoritative": {"const": false}}}}
  ]
}
