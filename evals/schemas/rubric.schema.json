{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/frame-business-research-problem/rubric.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "passing_score", "hard_failure_cap", "categories", "hard_failures"],
  "properties": {
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "passing_score": {"type": "integer", "minimum": 1, "maximum": 100},
    "hard_failure_cap": {"type": "integer", "minimum": 0, "maximum": 99},
    "categories": {
      "type": "array", "minItems": 8, "maxItems": 8,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "label", "weight", "anchors"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z_]+$"},
          "label": {"type": "string"},
          "weight": {"type": "integer", "minimum": 1},
          "anchors": {
            "type": "object", "additionalProperties": false,
            "required": ["zero", "half", "full"],
            "properties": {"zero": {"type": "string"}, "half": {"type": "string"}, "full": {"type": "string"}}
          }
        }
      }
    },
    "hard_failures": {
      "type": "array", "minItems": 9, "maxItems": 9,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["id", "description"],
        "properties": {"id": {"type": "string", "pattern": "^[a-z_]+$"}, "description": {"type": "string"}}
      }
    }
  }
}
