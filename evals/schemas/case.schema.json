{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/frame-business-research-problem/case.schema.json",
  "title": "Business-framing benchmark case",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "domain", "title", "prompt", "model_specification", "decision_time_facts", "fidelity_requirements", "prohibited_inferences", "evidence_needs", "hard_failure_traps", "adversarial", "tags"],
  "properties": {
    "id": {"type": "string", "pattern": "^(om|is|or)-[0-9]{2}$"},
    "domain": {"enum": ["OM", "IS", "OR"]},
    "title": {"type": "string", "minLength": 8},
    "prompt": {"type": "string", "minLength": 80},
    "model_specification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model_type", "mathematical_objective", "decision_variables", "state_variables", "constraints", "mechanism", "uncertainty"],
      "properties": {
        "model_type": {"type": "string", "minLength": 2},
        "mathematical_objective": {"type": "string", "minLength": 2},
        "decision_variables": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "state_variables": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "constraints": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "mechanism": {"type": "string", "minLength": 10},
        "uncertainty": {"type": "string", "minLength": 2}
      }
    },
    "decision_time_facts": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 2}},
    "fidelity_requirements": {"type": "array", "minItems": 2, "items": {"type": "string", "minLength": 2}},
    "prohibited_inferences": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 2}},
    "evidence_needs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim", "status", "source_needed"],
        "properties": {
          "claim": {"type": "string", "minLength": 2},
          "status": {"enum": ["empirical_fact", "model_assumption", "simplifying_assumption", "inference", "unsupported_claim"]},
          "source_needed": {"type": "boolean"}
        }
      }
    },
    "hard_failure_traps": {
      "type": "array",
      "items": {"enum": ["invented_company_fact", "unsupported_market_claim", "future_or_hidden_information", "objective_mismatch", "state_as_decision", "model_changed_for_story", "unsupported_causal_claim", "hidden_major_assumption", "welfare_claim_from_revenue"]}
    },
    "adversarial": {"type": "boolean"},
    "tags": {"type": "array", "minItems": 2, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z0-9-]+$"}}
  }
}
